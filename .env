# --- Mule / CloudHub ---
API_BASE="https://<your-cloudhub-app>.cloudhub.io/api"
# CLIENT_ID="..."
# CLIENT_SECRET="..."

# --- WebAuthn / Passkeys ---
RP_ID="<your-domain.com>"          # in dev: localhost
ORIGIN="https://<your-domain.com>" # in dev: http://localhost:8080
SESSION_SECRET="change-me"

# --- UI mode (optional) ---
APP_MODE="web"                     # "web" or "android"
WEB_PREFIX="/api"
# ANDROID_BASE="https://<cloudhub-app>.cloudhub.io/api"
